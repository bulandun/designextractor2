{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SemanticLayout",
  "type": "object",
  "required": ["sections", "inferred_role_map", "reading_order", "relationships", "page_template_type"],
  "properties": {
    "sections": { "type": "array", "items": { "$ref": "#/$defs/section" } },
    "inferred_role_map": { "type": "object" },
    "reading_order": { "type": "array", "items": { "type": "string" } },
    "relationships": { "type": "array", "items": { "$ref": "#/$defs/relationship" } },
    "page_template_type": { "$ref": "#/$defs/template" }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "role", "node_ids", "confidence"],
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "node_ids": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "alternatives": { "type": "array", "items": { "type": "object" } }
      }
    },
    "relationship": {
      "type": "object",
      "required": ["parent_id", "child_id", "relation", "confidence"],
      "properties": {
        "parent_id": { "type": "string" },
        "child_id": { "type": "string" },
        "relation": { "enum": ["contains", "follows", "linked_to"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "template": {
      "type": "object",
      "required": ["value", "confidence"],
      "properties": {
        "value": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "alternatives": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
